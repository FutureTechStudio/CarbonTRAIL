# Optional cloud AI for Panda (local demo only)
# WARNING: Do not commit real keys. Frontend keys are visible in the browser bundle.

# Local rule-based parser only (default)
VITE_AI_MODE=local

# Enable Gemini parser (demo/local only — use a backend proxy in production)
# VITE_AI_MODE=gemini
# VITE_GEMINI_API_KEY=your_key_here
# VITE_GEMINI_MODEL=gemini-2.0-flash

# Enable Mistral parser (demo/local only — use a backend proxy in production)
# VITE_AI_MODE=mistral
# VITE_MISTRAL_API_KEY=your_key_here
# VITE_MISTRAL_MODEL=mistral-small-latest

# Preferred production-safe proxy endpoint (serverless/backend)
# VITE_AI_PROXY_URL=/api/panda/parse

# Server-side only (not bundled by Vite)
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.0-flash
# MISTRAL_API_KEY=your_key_here
# MISTRAL_MODEL=mistral-small-latest
