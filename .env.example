# Optional cloud AI for Panda (local demo only)
# WARNING: Do not commit real keys. Never use VITE_* for API keys — they ship in the browser bundle.

# Local rule-based parser only (default)
VITE_AI_MODE=local

# Enable Mistral via dev proxy (recommended for local development)
# VITE_AI_MODE=mistral
# VITE_MISTRAL_MODEL=mistral-small-latest
# MISTRAL_API_KEY=your_key_here

# Enable Gemini via dev proxy
# VITE_AI_MODE=gemini
# VITE_GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=your_key_here

# Production: point the browser at your backend/serverless proxy
# VITE_AI_PROXY_URL=/api/panda/parse
# Set GEMINI_API_KEY or MISTRAL_API_KEY on the server only (not in Vite env)
